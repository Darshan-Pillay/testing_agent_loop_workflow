{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        ".",
        "/Users/darshanpillay/Documents/Personal/testing_agent_loop_workflow/.git"
      ],
      "denyRead": [
        "~/.ssh"
      ],
      "denyWrite": [
        "~",
        "/"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(git worktree:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr:*)"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm:*)"
    ],
    "deny": []
  }
}
